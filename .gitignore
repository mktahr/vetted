# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local
.env

# vercel
.vercel

# claude code IDE settings
.claude/

# typescript
*.tsbuildinfo
next-env.d.ts


# investigation raw data dumps (regenerable from scripts/_inv*.mjs)
docs/vetted-companies-v1/*-raw.json

# scratch scripts (workspace clutter)
scripts/_audit-companies.mjs
scripts/_check-all-tables.mjs
scripts/diagnose-*.mjs
scripts/simulate-*.mjs

# Eval harness data artifacts (real candidate text — reproducible via scripts/eval/freeze-fixture.ts)
reference/eval/*.json
reference/eval/*.csv
reference/eval/*.log
reference/eval/*.txt
